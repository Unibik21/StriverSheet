#include <vector>
using namespace std;

long findMinimumSum(vector<int> power) {
    long long ans = 0;

    for (int i = 0; i < power.size()-1; i++) {
        if (power[i+1] < power[i]) {
            ans += power[i]-power[i+1];
            for(int j=i+1;j<power.size();j++){
                power[j]+=ans;
            }
        }
    }

    return ans;
}